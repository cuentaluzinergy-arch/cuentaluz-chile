# CuentaLuz Chile — Variables de entorno
# Copiar a .env y completar antes de ejecutar en produccion

# Base de datos (Railway entrega postgres://, se convierte automaticamente)
# DATABASE_URL=postgresql://user:password@host:5432/cuentaluz

# Actualizacion automatica de tarifas
ENABLE_SCHEDULER=false
TARIFF_UPDATE_DAY=1

# Alertas por email
# ALERT_EMAIL=tu@email.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=contraseña_de_app_gmail

# Puerto (Railway/Render lo inyectan automaticamente)
# PORT=8000
