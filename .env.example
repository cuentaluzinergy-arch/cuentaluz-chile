# CuentaLuz Chile — Variables de entorno
# Copiar a .env y completar antes de ejecutar en produccion

# ── Servidor ────────────────────────────────────────────────
# Puerto (Railway/Render lo inyectan automaticamente)
# PORT=8000
BASE_URL=https://cuentaluz.cl

# ── Base de datos ────────────────────────────────────────────
# Railway entrega postgres://, se convierte automaticamente
# DATABASE_URL=postgresql://user:password@host:5432/cuentaluz

# ── Scheduler de tarifas ─────────────────────────────────────
ENABLE_SCHEDULER=false
TARIFF_UPDATE_DAY=1

# ── Email (SMTP) ─────────────────────────────────────────────
# Gmail: activa "Contraseñas de aplicacion" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=contraseña_de_app_gmail
# FROM_EMAIL=noreply@cuentaluz.cl

# Correo interno para alertas de actualizacion de tarifas
# ALERT_EMAIL=admin@cuentaluz.cl

# ── Afiliados ────────────────────────────────────────────────
# Numero WhatsApp del socio solar (con codigo de pais, sin +)
# Ejemplo: 56912345678
# SOLAR_WHATSAPP=

# ── Web Push (VAPID) ─────────────────────────────────────────
# Si no se configuran, se generan automáticamente en data/vapid_keys.json
# Para producción, copia los valores de ese archivo a variables de entorno:
# VAPID_PRIVATE_KEY=<clave privada PEM en una línea con \n escapados>
# VAPID_PUBLIC_KEY=<clave pública URL-safe base64, 87 chars>

# ── AdSense ──────────────────────────────────────────────────
# ID de editor de Google AdSense (una vez aprobada la cuenta)
# ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
